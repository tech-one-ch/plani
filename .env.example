# =============================================================================
# Plani — Environment variables example
# Turborepo telemetry — set to 1 to opt out of anonymous usage stats
TURBO_TELEMETRY_DISABLED=1
# =============================================================================
# Copy this file to `.env` and adjust the values for your environment.
# Never commit `.env` — only `.env.example`.
# =============================================================================

# ----- Application ----------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
# Extra origins trusted by better-auth (comma-separated). Set this when the app
# is accessed via a network IP, reverse proxy, or tunnel (e.g. VS Code port forwarding).
# TRUSTED_ORIGINS=http://192.168.1.100:3000,https://my-tunnel.example.com

# ----- Database (used from Phase 2 onwards) ----------------------------------
# Postgres connection string. Local dev assumes the docker-compose stack.
DATABASE_URL=postgres://plani:plani@localhost:5432/plani

# ----- Authentication (used from Phase 3 onwards) ----------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional — only needed if you enable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- SMTP -------------------------------------------------------------------
# Leave SMTP_HOST unset (or as "localhost") to disable email sending entirely.
# Without SMTP, accounts work without email verification (good for self-hosting
# when you don't want to set up a mail server).
#
# For local dev with Mailhog: set SMTP_HOST=localhost, SMTP_PORT=1025, leave
# SMTP_USER and SMTP_PASS empty. Mailhog UI at http://localhost:8025.
#
# For production: fill in your SMTP provider credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Plani <no-reply@plani.app>"
SMTP_SECURE=false

# Require users to verify their email before they can log in.
# Only takes effect when SMTP is configured. Default: false (open self-hosting).
REQUIRE_EMAIL_VERIFICATION=false

# ----- Instance settings ------------------------------------------------------
# Allow open user registration. Set to false to disable public sign-up
# (invite-only mode). Can also be toggled from the admin panel (Phase 4).
ALLOW_SIGNUP=true
