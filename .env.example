# =============================================================================
# Plani — Environment variables example
# Turborepo telemetry — set to 1 to opt out of anonymous usage stats
TURBO_TELEMETRY_DISABLED=1
# =============================================================================
# Copy this file to `.env` and adjust the values for your environment.
# Never commit `.env` — only `.env.example`.
# =============================================================================

# ----- Application ----------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# ----- Database (used from Phase 2 onwards) ----------------------------------
# Postgres connection string. Local dev assumes the docker-compose stack.
DATABASE_URL=postgres://plani:plani@localhost:5432/plani

# ----- Authentication (used from Phase 3 onwards) ----------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional — only needed if you enable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- SMTP (used from Phase 3 onwards) --------------------------------------
# Local dev uses Mailhog (port 1025 SMTP, port 8025 web UI).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Plani <no-reply@plani.local>"
SMTP_SECURE=false

# ----- Instance settings (used from Phase 4 onwards) -------------------------
# Email of the first instance admin to provision automatically on first boot.
# Leave empty to disable auto-provisioning.
INSTANCE_ADMIN_EMAIL=

# Allow open user registration by default. Overridable from the admin panel.
ALLOW_SIGNUP=true
